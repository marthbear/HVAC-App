rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null;

      // Users can write to their own document
      allow write: if request.auth != null && request.auth.uid == userId;

      // Allow admins to update users in their company (for approving/rejecting employees)
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId;

      // Allow admins to delete users in their company (for rejecting employees)
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId;
    }

    // Time entries - users can manage their own entries
    match /timeEntries/{entryId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Jobs collection
    match /jobs/{jobId} {
      allow read, write: if request.auth != null;
    }

    // Employees collection (for scheduling)
    match /employees/{employeeId} {
      allow read, write: if request.auth != null;
    }

    // Service requests
    match /serviceRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // Companies
    match /companies/{companyId} {
      allow read, write: if request.auth != null;
    }

    // Bug reports
    match /bugReports/{reportId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null;
    }

    // Email logs (admin only)
    match /emailLogs/{logId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null;
    }
  }
}
